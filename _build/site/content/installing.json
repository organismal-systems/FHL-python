{"version":3,"kind":"Article","sha256":"4c0a1522329f3a713cd28d248cde3c57c22640cfaad8f091d5a67fb01cb8a6a0","slug":"installing","location":"/00-1-installing.md","dependencies":[],"frontmatter":{"title":"Installing python","short_title":"Prelude: installing python","authors":[{"nameParsed":{"literal":"Wing-Ho Ko","given":"Wing-Ho","family":"Ko"},"name":"Wing-Ho Ko","affiliations":["School of Oceanography, University of Washington"],"id":"contributors-Users\\wingho\\git\\FHL-python\\myst-generated-uid-0"}],"keywords":["python","models"],"affiliations":[{"id":"School of Oceanography, University of Washington","name":"School of Oceanography, University of Washington"}],"thumbnail":"/mamba_base-adc6989dac0499b8b46ed2d220c7413f.png","exports":[{"format":"md","filename":"00-1-installing.md","url":"/00-1-installing-3aadfaee8c75005cfb05951f06f4e79d.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"children":[{"type":"text","value":"Installing the miniforge python distribution","position":{"start":{"line":6,"column":1},"end":{"line":6,"column":1}},"key":"sgOakfVz32"}],"identifier":"installing-the-miniforge-python-distribution","label":"Installing the miniforge python distribution","html_id":"installing-the-miniforge-python-distribution","implicit":true,"key":"tF9oz1EyVK"},{"type":"paragraph","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"There are a number of ways to install python locally on your computer. We recommend using the ","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"WkOhlm5isV"},{"type":"link","url":"https://conda-forge.org/download/","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"children":[{"type":"text","value":"miniforge distribution","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"qxGdfCStvl"}],"urlSource":"https://conda-forge.org/download/","key":"o5IE7zRdMG"},{"type":"text","value":".","position":{"start":{"line":8,"column":1},"end":{"line":8,"column":1}},"key":"VTIynJehyJ"}],"key":"F2LtXDfT4s"},{"type":"paragraph","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"children":[{"type":"text","value":"Head to the linked page and download the installer suitable for your OS. Once the installer is downloaded, follow the installation instruction and install the miniforge distribution. Once miniforge is installed, start a terminal (command prompt in Windows, Terminal in MacOS, etc.) with the base mamba environment activated (in Windows there is a separate icon for that, in Mac your Terminal should be configured to activate the base environment automatically). A mamba enabled terminal with the base environment activated should have a prompt that started with the text ","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"BheHzvKusX"},{"type":"inlineCode","value":"(base)","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"XDnRH0NT3N"},{"type":"text","value":".","position":{"start":{"line":10,"column":1},"end":{"line":10,"column":1}},"key":"Y6ufo8CqkC"}],"key":"ErnXq3XHBq"},{"type":"image","url":"/mamba_base-adc6989dac0499b8b46ed2d220c7413f.png","alt":"A mamba enabled terminal","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"BaLYvDojR9","urlSource":"img/mamba_base.png"},{"type":"paragraph","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"strong","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"children":[{"type":"text","value":"Figure","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"Yhi0u9qfwf"}],"key":"hYoYzxltnC"},{"type":"text","value":": A mamba enabled terminal.","position":{"start":{"line":14,"column":1},"end":{"line":14,"column":1}},"key":"FF2xHYnTcd"}]