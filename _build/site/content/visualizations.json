html_id":"plot-types","implicit":true,"key":"SdWWmtlw8E"}],"key":"sSmrB0Q9pF"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# scatter plot\n\nx_array = np.random.normal(0, 1, 100)\ny_array = 0.2 * x_array + 0.8 * np.random.normal(0, 1, 100)\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nax.scatter(x_array, y_array, marker=\".\")\n\nplt.show(fig)","key":"VrnMKnc1Ai"},{"type":"outputs","id":"8KtuXcYrmDf-UBK5D3Iep","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"a3c73690342027636c0c67a499690a2b","path":"/a3c73690342027636c0c67a499690a2b.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"IO6dzkzmtY"}],"key":"enNCqaJgW4"}],"key":"SNMPwrh6Tk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# error bar plot\n\nx_data = np.arange(0, 5.1, 0.5)\ny_data = np.sqrt(x_data)\ny_err = np.array([\n    [0.4, 0.3, 0.3, 0.2, 0.4, 0.4, 0.3, 0.2, 0.2, 0.3, 0.3], # lower\n    [0.1, 0.2, 0.2, 0.1, 0.2, 0.2, 0.1, 0.1, 0.2, 0.2, 0.2] # Upper\n])\nx_err = 0.1\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nplt.errorbar(\n    x_data, y_data, yerr = y_err, xerr = x_err, \n    color=\"blue\", marker=\"o\", lw=1, ls=\"--\", \n    ecolor=\"black\", capsize=3.0\n)\n\nplt.show(fig)\n\n","key":"q94PRDLrNY"},{"type":"outputs","id":"o2ds1__IviQjDXv_OSqHU","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"e81d87632e0a041d93ab3eb58b6a7291","path":"/e81d87632e0a041d93ab3eb58b6a7291.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"y5w9GCtivk"}],"key":"HSmzXFQeEr"}],"key":"kGnoMHvelA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# bar plot with error bars\n# different color for each bar\n\nx_data = np.arange(0, 5)\ny_data = np.array([6, 5, 9, 4, 7])\n\ny_err = np.array([0.7, 0.4, 0.3, 0.5, 0.2])\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nax.bar(\n    x_data, y_data, align=\"center\", width=0.8,\n    tick_label = [\"apple\", \"banana\", \"lemon\", \"grape\", \"orange\"],\n    color=[\"tab:blue\", \"tab:orange\", \"tab:green\", \"tab:red\", \"tab:purple\"],\n    yerr = y_err, ecolor=\"black\", capsize=5\n)\n\nplt.show(fig)\n\n","key":"SQlx7et0Vp"},{"type":"outputs","id":"yf_3BKmx1ss570k4mbb6Z","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"356d6576d5e15c361764cb575fe0a343","path":"/356d6576d5e15c361764cb575fe0a343.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"z1V7FnaL4j"}],"key":"CRNrvZ3Xrq"}],"key":"TdwmiGK2yK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 2D false color plot\n\nX = np.linspace(-2, 2, 201)\nY = np.linspace(-1, 1, 101)\n\nX_grid, Y_grid = np.meshgrid(X, Y)\nZ = np.exp(-X_grid**2 - 0.5 * Y_grid**2)\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nmesh = ax.pcolormesh(X, Y, Z, cmap=\"magma\")\ncb = fig.colorbar(mesh, aspect=15)\n\nplt.show()","key":"vA062OOSOs"},{"type":"outputs","id":"Jk5pfmzOggBG9IsHeO7WB","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"b6c6eece62c487bd76a42809cfa912f1","path":"/b6c6eece62c487bd76a42809cfa912f1.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"LvGe6gzCRH"}],"key":"jEd2OevFMy"}],"key":"XaUukqKTi4"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plotting from data file: body mass–metabolism allometry","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"FhCMRF8UIT"}],"identifier":"plotting-from-data-file-body-mass-metabolism-allometry","label":"Plotting from data file: body mass–metabolism allometry","html_id":"plotting-from-data-file-body-mass-metabolism-allometry","implicit":true,"key":"hg118uhnEM"}],"key":"fKbirJu9ta"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"strong","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Data source","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"tHMO6Y3Gt0"}],"key":"OSM3PkhEj9"},{"type":"text","value":": White et. al., ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"iy5NYhuGj1"},{"type":"cite","url":"https://doi.org/10.1098/rsbl.2005.0378","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The scaling and temperature dependence of vertebrate metabolism","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OGiV9ir53Q"}],"key":"xuDlrTLbTp"}],"kind":"narrative","label":"White_2005","identifier":"https://doi.org/10.1098/rsbl.2005.0378","enumerator":"1","key":"mGpBAikCOj"}],"key":"moZAm7nYfp"}],"key":"E2ZwFquRKc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# loading dataset using pandas\n\ndf = pd.read_csv(\"data/allometry.csv\", index_col=None)\ndf.info()","key":"BihEUIFdDM"},{"type":"outputs","id":"UeJNubciFSD-ViXTKUWVW","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"<class 'pandas.core.frame.DataFrame'>\nRangeIndex: 455 entries, 0 to 454\nData columns (total 7 columns):\n #   Column       Non-Null Count  Dtype  \n---  ------       --------------  -----  \n 0   Species      455 non-null    object \n 1   Mass         455 non-null    float64\n 2   Temperature  455 non-null    float64\n 3   MR           455 non-null    float64\n 4   AvgMass      455 non-null    float64\n 5   Q10SMR       455 non-null    float64\n 6   Reference    455 non-null    object \ndtypes: float64(5), object(2)\nmemory usage: 25.0+ KB\n"},"children":[],"key":"ZSUJUccP5r"}],"key":"qR9f8WLi37"}],"key":"pAfTIfcPMM"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# compute regression coefficients for the power law\n\nfrom scipy.stats import linregress\nfit = linregress(np.log(df[\"AvgMass\"]), np.log(df[\"Q10SMR\"]))\nprint(fit.slope, fit.intercept)","key":"Uo5IQCRMu1"},{"type":"outputs","id":"YoYVgYId2AdNhHwaVW_aK","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"0.6757560070445262 1.6046478631493089\n"},"children":[],"key":"CHz9hJMLJ0"}],"key":"T2gnkaUIIO"}],"key":"WUrZtnojzB"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# generate best fit curve\n\nMass_th = np.geomspace(np.min(df[\"AvgMass\"]), np.max(df[\"AvgMass\"]), 100)\nQ10_th = np.exp(fit.intercept + fit.slope * np.log(Mass_th))","key":"NbBR3QBDFb"},{"type":"outputs","id":"alznyVZIXgqnl2pYz0g-l","children":[],"key":"HjapUsy9wk"}],"key":"fsxkaZnB8t"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Plot the data and fit on log-log scale\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nax.scatter(df[\"AvgMass\"], df[\"Q10SMR\"], marker=\".\", c=\"tab:blue\")\nax.plot(Mass_th, Q10_th, lw=2, ls=\"--\", c=\"tab:orange\")\n\nax.set_title(\"Body mass–metabolism allometry\")\nax.set_xlabel(\"Body mass (g)\")\nax.set_ylabel(\"SMR (mL O$_2$ h$^{-1}$)\")\n\nax.set_xscale(\"log\", base=10)\nax.set_yscale(\"log\", base=10)\n\n# save the figure to image file\n#fig.savefig(\"allometry.png\")\n\nplt.show(fig)","key":"BwcJATRqae"},{"type":"outputs","id":"TR8SBlXsn44bRyMW8opfz","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"0ab8c0107ccc4a92db303f9b0f3275a3","path":"/0ab8c0107ccc4a92db303f9b0f3275a3.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"tNJEdk4KyU"}],"key":"pcj6OHWvSL"}],"key":"klphFTFOXR"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Exercise: plot your own data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NRZKslN0yS"}],"identifier":"exercise-plot-your-own-data","label":"Exercise: plot your own data","html_id":"exercise-plot-your-own-data","implicit":true,"key":"infNWwq98U"}],"key":"zegnVYht8K"}],"key":"ZbnbhknI8M"},"references":{"cite":{"order":["White_2005"],"data":{"White_2005":{"label":"White_2005","enumerator":"1","doi":"10.1098/rsbl.2005.0378","html":"White, C. R., Phillips, N. F., & Seymour, R. S. (2005). The scaling and temperature dependence of vertebrate metabolism. <i>Biology Letters</i>, <i>2</i>(1), 125–127. <a target=\"_blank\" rel=\"noreferrer\" href=\"https://doi.org/10.1098/rsbl.2005.0378\">10.1098/rsbl.2005.0378</a>","url":"https://doi.org/10.1098/rsbl.2005.0378"}}}}}