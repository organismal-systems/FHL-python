l#axes-plotting-methods","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"“Introduction to Axes”","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"E3rhvHaYEE"}],"urlSource":"https://matplotlib.org/stable/users/explain/axes/axes_intro.html#axes-plotting-methods","key":"QBGXUQuW2t"},{"type":"text","value":" page and the resources therein.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"wnP8fVOjq1"}],"key":"lTSSXC5adx"}],"key":"VoTBdDrHd0"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plot types","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"aV9jlO0bL2"}],"identifier":"plot-types","label":"Plot types","html_id":"plot-types","implicit":true,"key":"Wqf5AeuF1v"}],"key":"aY51thp49h"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# scatter plot\n\nx_array = np.random.normal(0, 1, 100)\ny_array = 0.2 * x_array + 0.8 * np.random.normal(0, 1, 100)\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nax.scatter(x_array, y_array, marker=\".\")\n\nplt.show(fig)","key":"Poe7bUyCUF"},{"type":"outputs","id":"aCFWEEL0yYeUMqod3AoxR","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"a3c73690342027636c0c67a499690a2b","path":"/a3c73690342027636c0c67a499690a2b.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"PBYIzDfida"}],"key":"Nuvv1CWTph"}],"key":"MUmQUBbxJk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# error bar plot\n\nx_data = np.arange(0, 5.1, 0.5)\ny_data = np.sqrt(x_data)\ny_err = np.array([\n    [0.4, 0.3, 0.3, 0.2, 0.4, 0.4, 0.3, 0.2, 0.2, 0.3, 0.3], # lower\n    [0.1, 0.2, 0.2, 0.1, 0.2, 0.2, 0.1, 0.1, 0.2, 0.2, 0.2] # Upper\n])\nx_err = 0.1\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nplt.errorbar(\n    x_data, y_data, yerr = y_err, xerr = x_err, \n    color=\"blue\", marker=\"o\", lw=1, ls=\"--\", \n    ecolor=\"black\", capsize=3.0\n)\n\nplt.show(fig)\n\n","key":"JXWM3TpisN"},{"type":"outputs","id":"vOCBXmFG2m6n4zdlrMlna","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"e81d87632e0a041d93ab3eb58b6a7291","path":"/e81d87632e0a041d93ab3eb58b6a7291.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"TfCNlqrfbE"}],"key":"tA1aR4aNbq"}],"key":"HTN34oQfLZ"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# bar plot with error bars\n# different color for each bar\n\nx_data = np.arange(0, 5)\ny_data = np.array([6, 5, 9, 4, 7])\n\ny_err = np.array([0.7, 0.4, 0.3, 0.5, 0.2])\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nax.bar(\n    x_data, y_data, align=\"center\", width=0.8,\n    tick_label = [\"apple\", \"banana\", \"lemon\", \"grape\", \"orange\"],\n    color=[\"tab:blue\", \"tab:orange\", \"tab:green\", \"tab:red\", \"tab:purple\"],\n    yerr = y_err, ecolor=\"black\", capsize=5\n)\n\nplt.show(fig)\n\n","key":"vDCxXgGRAy"},{"type":"outputs","id":"R3sgNTntL0fuldSkYtl1Q","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"356d6576d5e15c361764cb575fe0a343","path":"/356d6576d5e15c361764cb575fe0a343.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"AtEtQ9ILCs"}],"key":"XDhJe0W8gc"}],"key":"Y99pYWgEnm"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 2D false color plot\n\nX = np.linspace(-2, 2, 201)\nY = np.linspace(-1, 1, 101)\n\nX_grid, Y_grid = np.meshgrid(X, Y)\nZ = np.exp(-X_grid**2 - 0.5 * Y_grid**2)\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nmesh = ax.pcolormesh(X, Y, Z, cmap=\"magma\")\ncb = fig.colorbar(mesh, aspect=15)\n\nplt.show()","key":"xptcD4vYIy"},{"type":"outputs","id":"qDt4QSWy8BzPhrUw8RDTy","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"b6c6eece62c487bd76a42809cfa912f1","path":"/b6c6eece62c487bd76a42809cfa912f1.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"kMYtyGo8Pg"}],"key":"grQzdP1jgt"}],"key":"a3cq2LR9jd"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"For more plot types, see the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"J9SxcgLhNd"},{"type":"inlineCode","value":"matplotlib","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"EMml8pBKs3"},{"type":"text","value":" ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"yHbX2rVOzP"},{"type":"link","url":"https://matplotlib.org/stable/plot_types/index.html","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"plot types overview","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"YELd82ESA2"}],"urlSource":"https://matplotlib.org/stable/plot_types/index.html","key":"nw6PAUEvcx"},{"type":"text","value":" and the resources therein.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"OjTpiAQKzY"}],"key":"Oc4DGxqtX6"}],"key":"Yr6DVnmG9b"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plotting from data file: body mass–metabolism allometry","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Zc744he8zX"}],"identifier":"plotting-from-data-file-body-mass-metabolism-allometry","label":"Plotting from data file: body mass–metabolism allometry","html_id":"plotting-from-data-file-body-mass-metabolism-allometry","implicit":true,"key":"rJ1PCvgViq"}],"key":"unPyYMG0n6"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"strong","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Data source","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ad76Wj8Aq8"}],"key":"d1Zm278LAC"},{"type":"text","value":": White et. al., ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hmJ9H8m18b"},{"type":"cite","url":"https://doi.org/10.1098/rsbl.2005.0378","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The scaling and temperature dependence of vertebrate metabolism","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"urgVy85mK6"}],"key":"IScQNz51Ua"}],"kind":"narrative","label":"White_2005","identifier":"https://doi.org/10.1098/rsbl.2005.0378","enumerator":"1","key":"akkgD5e3X9"}],"key":"wjPyRnw4VZ"}],"key":"uPGhYYkGkp"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# loading dataset using pandas\n\ndf = pd.read_csv(\"data/allometry.csv\", index_col=None)\ndf.info()","key":"tztyGLNmpg"},{"type":"outputs","id":"rQ9QT0iVxfY_SBBeh1Y5t","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"<class 'pandas.core.frame.DataFrame'>\nRangeIndex: 455 entries, 0 to 454\nData columns (total 7 columns):\n #   Column       Non-Null Count  Dtype  \n---  ------       --------------  -----  \n 0   Species      455 non-null    object \n 1   Mass         455 non-null    float64\n 2   Temperature  455 non-null    float64\n 3   MR           455 non-null    float64\n 4   AvgMass      455 non-null    float64\n 5   Q10SMR       455 non-null    float64\n 6   Reference    455 non-null    object \ndtypes: float64(5), object(2)\nmemory usage: 25.0+ KB\n"},"children":[],"key":"pvnNr26AJF"}],"key":"nd0Z8Gcm1T"}],"key":"NhAyFsgK4k"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"strong","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Note","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"qk16vo8APP"}],"key":"kDgdhYL8UK"},{"type":"text","value":": pandas support a wide variety of input file formats. See ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"H0BjSPAEod"},{"type":"inlineCode","value":"pandas","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"bmknyXdy1K"},{"type":"text","value":" ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Y9ZdFmjmGL"},{"type":"link","url":"https://pandas.pydata.org/docs/reference/io.html","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Input/output page","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"VvV01JvER8"}],"urlSource":"https://pandas.pydata.org/docs/reference/io.html","key":"a5xNeZsbPk"},{"type":"text","value":" for more information.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"W23MGOrNhq"}],"key":"BY9BAYss4t"}],"key":"dzoDDdRsvn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# compute regression coefficients for the power law\n\nfrom scipy.stats import linregress\nfit = linregress(np.log(df[\"AvgMass\"]), np.log(df[\"Q10SMR\"]))\nprint(fit.slope, fit.intercept)","key":"Aq0oWWb76B"},{"type":"outputs","id":"AOdb7ttQDa8YenYfF9qtp","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"0.6757560070445262 1.6046478631493089\n"},"children":[],"key":"Lf2Ws8zNE7"}],"key":"zyZ7LhmO5Y"}],"key":"m54haq9yRY"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# generate best fit curve\n\nMass_th = np.geomspace(np.min(df[\"AvgMass\"]), np.max(df[\"AvgMass\"]), 100)\nQ10_th = np.exp(fit.intercept + fit.slope * np.log(Mass_th))","key":"koReTc4P88"},{"type":"outputs","id":"4HmfKLBw4n4taNv2IFW9f","children":[],"key":"kgbEXGGQWd"}],"key":"fzgeWtgSkk"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Plot the data and fit on log-log scale\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nax.scatter(df[\"AvgMass\"], df[\"Q10SMR\"], marker=\".\", c=\"tab:blue\")\nax.plot(Mass_th, Q10_th, lw=2, ls=\"--\", c=\"tab:orange\")\n\nax.set_title(\"Body mass–metabolism allometry\")\nax.set_xlabel(\"Body mass (g)\")\nax.set_ylabel(\"SMR (mL O$_2$ h$^{-1}$)\")\n\nax.set_xscale(\"log\", base=10)\nax.set_yscale(\"log\", base=10)\n\n# save the figure to image file\n#fig.savefig(\"allometry.png\")\n\nplt.show(fig)","key":"cywUHFXQO4"},{"type":"outputs","id":"heP_7ws1NXdCuIVz_mfDt","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"0ab8c0107ccc4a92db303f9b0f3275a3","path":"/0ab8c0107ccc4a92db303f9b0f3275a3.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"mICUKG7xpo"}],"key":"seKJTd6lJq"}],"key":"D1ALyeFIpb"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Exercise: plot your own data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"gbgagSZnF9"}],"identifier":"exercise-plot-your-own-data","label":"Exercise: plot your own data","html_id":"exercise-plot-your-own-data","implicit":true,"key":"lgvurb0uiW"}],"key":"YwRGtQ7qEM"}],"key":"axrPMwOvxB"},"references":{"cite":{"order":["White_2005"],"data":{"White_2005":{"label":"White_2005","enumerator":"1","doi":"10.1098/rsbl.2005.0378","html":"White, C. R., Phillips, N. F., & Seymour, R. S. (2005). The scaling and temperature dependence of vertebrate metabolism. <i>Biology Letters</i>, <i>2</i>(1), 125–127. <a target=\"_blank\" rel=\"noreferrer\" href=\"https://doi.org/10.1098/rsbl.2005.0378\">10.1098/rsbl.2005.0378</a>","url":"https://doi.org/10.1098/rsbl.2005.0378"}}}}}