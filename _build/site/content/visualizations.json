],"key":"UT8qxZWRMc"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Completing our previous plot by adding plot elements and specifying styles:","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JuLqSPqMDO"}],"key":"OKkQAFIL4d"}],"key":"PhIcwqGUF9"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure()\nax = fig.add_subplot()\n\nax.plot(x_array, y_array, lw=2, ls=\"--\", c=\"tab:purple\")\n\nax.set_xlim([0, 1])\nax.set_ylim([0, 1])\n\nax.grid(ls=\":\")\n\nax.set_xticks(np.arange(0, 1.05, 0.25))\nax.set_yticks(np.arange(0, 1.05, 0.25))\n\nax.set_xticks(np.arange(0, 1.01, 0.05), minor=True)\nax.set_yticks(np.arange(0, 1.01, 0.05), minor=True)\nax.tick_params(\"both\", labelsize=11)\n\nax.set_title(\"The square root function\", fontsize=14)\nax.set_xlabel(\"x-coordinate\", fontsize=12)\nax.set_ylabel(\"y-coordinate\", fontsize=12)\n\nplt.show(fig)","key":"NMUvazraYG"},{"type":"outputs","id":"5j3KwaLUBfVydF-8060CD","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"613ee2fb425d71d2e1a13f86b7fb976b","path":"/613ee2fb425d71d2e1a13f86b7fb976b.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"Vhe1l7slzD"}],"key":"lMvB5ljTjC"}],"key":"jAENkW9qAZ"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"For more information about the various plot elements, refer to the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"todql5f2Yp"},{"type":"inlineCode","value":"matplotlib","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nyQ43TKvOH"},{"type":"text","value":" ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"jqvJZCdMA5"},{"type":"link","url":"https://matplotlib.org/stable/users/explain/axes/axes_intro.html#axes-plotting-methods","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"“Introduction to Axes”","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"z9RtFtyf3i"}],"urlSource":"https://matplotlib.org/stable/users/explain/axes/axes_intro.html#axes-plotting-methods","key":"wL3fS5OUCi"},{"type":"text","value":" page and the resources therein.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"xGegoZHAuS"}],"key":"DZ23GhS2He"}],"key":"DOPP2Vm8X9"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plot types","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"kxBs2kAQFq"}],"identifier":"plot-types","label":"Plot types","html_id":"plot-types","implicit":true,"key":"NGNoFP6zDG"}],"key":"zwxOmhVUZx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# scatter plot\n\nx_array = np.random.normal(0, 1, 100)\ny_array = 0.2 * x_array + 0.8 * np.random.normal(0, 1, 100)\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nax.scatter(x_array, y_array, marker=\".\")\n\nplt.show(fig)","key":"UfdNjhyvea"},{"type":"outputs","id":"T_LnwmiFrYIDknaIpkTmy","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"a3c73690342027636c0c67a499690a2b","path":"/a3c73690342027636c0c67a499690a2b.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"UB1DSOekDL"}],"key":"MC1bMVnXa5"}],"key":"PXo7sW7Y0G"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# error bar plot\n\nx_data = np.arange(0, 5.1, 0.5)\ny_data = np.sqrt(x_data)\ny_err = np.array([\n    [0.4, 0.3, 0.3, 0.2, 0.4, 0.4, 0.3, 0.2, 0.2, 0.3, 0.3], # lower\n    [0.1, 0.2, 0.2, 0.1, 0.2, 0.2, 0.1, 0.1, 0.2, 0.2, 0.2] # Upper\n])\nx_err = 0.1\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nplt.errorbar(\n    x_data, y_data, yerr = y_err, xerr = x_err, \n    color=\"blue\", marker=\"o\", lw=1, ls=\"--\", \n    ecolor=\"black\", capsize=3.0\n)\n\nplt.show(fig)\n\n","key":"SX7sQWLpoN"},{"type":"outputs","id":"5TcYTLMsb9fT122hQaax3","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"e81d87632e0a041d93ab3eb58b6a7291","path":"/e81d87632e0a041d93ab3eb58b6a7291.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"WETBtjQrsQ"}],"key":"CSrYQHIaQj"}],"key":"r2xCAAIgkc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# bar plot with error bars\n# different color for each bar\n\nx_data = np.arange(0, 5)\ny_data = np.array([6, 5, 9, 4, 7])\n\ny_err = np.array([0.7, 0.4, 0.3, 0.5, 0.2])\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nax.bar(\n    x_data, y_data, align=\"center\", width=0.8,\n    tick_label = [\"apple\", \"banana\", \"lemon\", \"grape\", \"orange\"],\n    color=[\"tab:blue\", \"tab:orange\", \"tab:green\", \"tab:red\", \"tab:purple\"],\n    yerr = y_err, ecolor=\"black\", capsize=5\n)\n\nplt.show(fig)\n\n","key":"vrg9P8NlQT"},{"type":"outputs","id":"ScGF6ihnYl68pqX0lk_n4","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"356d6576d5e15c361764cb575fe0a343","path":"/356d6576d5e15c361764cb575fe0a343.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"JauwhCxmLg"}],"key":"wixV01wj2a"}],"key":"rE4OSWOBCx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# 2D false color plot\n\nX = np.linspace(-2, 2, 201)\nY = np.linspace(-1, 1, 101)\n\nX_grid, Y_grid = np.meshgrid(X, Y)\nZ = np.exp(-X_grid**2 - 0.5 * Y_grid**2)\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nmesh = ax.pcolormesh(X, Y, Z, cmap=\"magma\")\ncb = fig.colorbar(mesh, aspect=15)\n\nplt.show()","key":"ZQpQj4okNb"},{"type":"outputs","id":"rUBI0VErsN09aMRrlYo3k","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"b6c6eece62c487bd76a42809cfa912f1","path":"/b6c6eece62c487bd76a42809cfa912f1.png"},"text/plain":{"content":"<Figure size 640x480 with 2 Axes>","content_type":"text/plain"}}},"children":[],"key":"rHzRzCOZNA"}],"key":"bM7KgYAXrA"}],"key":"HwKo1KaIkT"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"For more plot types, see the ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"sVBEZ0cBkQ"},{"type":"inlineCode","value":"matplotlib","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"z3535JXm7A"},{"type":"text","value":" ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"n5LkQnROPt"},{"type":"link","url":"https://matplotlib.org/stable/plot_types/index.html","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"plot types overview","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nfitfwQJKa"}],"urlSource":"https://matplotlib.org/stable/plot_types/index.html","key":"Ul8EetIOiZ"},{"type":"text","value":" and the resources therein.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"YLkEswYtkK"}],"key":"ATKdA03R9d"}],"key":"tmv4tS8mZK"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plotting from data file: body mass–metabolism allometry","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"aNooK9G19u"}],"identifier":"plotting-from-data-file-body-mass-metabolism-allometry","label":"Plotting from data file: body mass–metabolism allometry","html_id":"plotting-from-data-file-body-mass-metabolism-allometry","implicit":true,"key":"Xqom4xaosx"}],"key":"xOOmCsnO2B"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"strong","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Data source","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"n7VnhW08lL"}],"key":"SESGlrC6Jz"},{"type":"text","value":": White et. al., ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mCmH5CKM3X"},{"type":"cite","url":"https://doi.org/10.1098/rsbl.2005.0378","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"emphasis","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"The scaling and temperature dependence of vertebrate metabolism","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"nFtSO4jP0H"}],"key":"hCEKu55uCh"}],"kind":"narrative","label":"White_2005","identifier":"https://doi.org/10.1098/rsbl.2005.0378","enumerator":"1","key":"OBIGvrEf9e"}],"key":"GdXkOiY12u"}],"key":"msyCGg6dTt"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# loading dataset using pandas\n\ndf = pd.read_csv(\"data/allometry.csv\", index_col=None)\ndf.info()","key":"oCeZ6uvNxo"},{"type":"outputs","id":"XzEmp4uGm8_oe6_5XdhZL","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"<class 'pandas.core.frame.DataFrame'>\nRangeIndex: 455 entries, 0 to 454\nData columns (total 7 columns):\n #   Column       Non-Null Count  Dtype  \n---  ------       --------------  -----  \n 0   Species      455 non-null    object \n 1   Mass         455 non-null    float64\n 2   Temperature  455 non-null    float64\n 3   MR           455 non-null    float64\n 4   AvgMass      455 non-null    float64\n 5   Q10SMR       455 non-null    float64\n 6   Reference    455 non-null    object \ndtypes: float64(5), object(2)\nmemory usage: 25.0+ KB\n"},"children":[],"key":"OObXaVadPx"}],"key":"azwqynAQOB"}],"key":"tNQ7HtE7LF"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"strong","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Note","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Ty3oVQlp1Q"}],"key":"cVTdiiKmRO"},{"type":"text","value":": pandas support a wide variety of input file formats. See ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"cqd0ExfpYX"},{"type":"inlineCode","value":"pandas","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"y69fKYW2uf"},{"type":"text","value":" ","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"PnzI8nEvRP"},{"type":"link","url":"https://pandas.pydata.org/docs/reference/io.html","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Input/output page","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NsSfOsOgR3"}],"urlSource":"https://pandas.pydata.org/docs/reference/io.html","key":"Q8M22bB8QN"},{"type":"text","value":" for more information.","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"TumvQmARLp"}],"key":"vbjLxI5Oqp"}],"key":"jgm4vTxxQK"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# compute regression coefficients for the power law\n\nfrom scipy.stats import linregress\nfit = linregress(np.log(df[\"AvgMass\"]), np.log(df[\"Q10SMR\"]))\nprint(fit.slope, fit.intercept)","key":"or1Xai5Dqv"},{"type":"outputs","id":"XORAjvStbp9RCgkZaxEzY","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"0.6757560070445262 1.6046478631493089\n"},"children":[],"key":"qHIVmPjm4g"}],"key":"KTanZklHXT"}],"key":"ZCls4HBibv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# generate best fit curve\n\nMass_th = np.geomspace(np.min(df[\"AvgMass\"]), np.max(df[\"AvgMass\"]), 100)\nQ10_th = np.exp(fit.intercept + fit.slope * np.log(Mass_th))","key":"CiVAg3C40H"},{"type":"outputs","id":"fQUJ8vfi5vbRVlXSrSZTM","children":[],"key":"Z6YC4iNXdk"}],"key":"SHfVYjTf4O"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Plot the data and fit on log-log scale\n\nfig = plt.figure()\nax = fig.add_subplot()\n\nax.scatter(df[\"AvgMass\"], df[\"Q10SMR\"], marker=\".\", c=\"tab:blue\")\nax.plot(Mass_th, Q10_th, lw=2, ls=\"--\", c=\"tab:orange\")\n\nax.set_title(\"Body mass–metabolism allometry\")\nax.set_xlabel(\"Body mass (g)\")\nax.set_ylabel(\"SMR (mL O$_2$ h$^{-1}$)\")\n\nax.set_xscale(\"log\", base=10)\nax.set_yscale(\"log\", base=10)\n\n# save the figure to image file\n#fig.savefig(\"allometry.png\")\n\nplt.show(fig)","key":"jt3EEcCA1J"},{"type":"outputs","id":"GD9dUuMAVEia9RWyxHxjp","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"image/png":{"content_type":"image/png","hash":"0ab8c0107ccc4a92db303f9b0f3275a3","path":"/0ab8c0107ccc4a92db303f9b0f3275a3.png"},"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"}}},"children":[],"key":"JBxqgm0Y5l"}],"key":"umQThCYD5Y"}],"key":"sVWJLIUm3Z"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Exercise: plot your own data","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"CPDbsot66Z"}],"identifier":"exercise-plot-your-own-data","label":"Exercise: plot your own data","html_id":"exercise-plot-your-own-data","implicit":true,"key":"MgXY90Q68n"}],"key":"sFVlxwTjUh"}],"key":"B4IPaKSLfh"},"references":{"cite":{"order":["White_2005"],"data":{"White_2005":{"label":"White_2005","enumerator":"1","doi":"10.1098/rsbl.2005.0378","html":"White, C. R., Phillips, N. F., & Seymour, R. S. (2005). The scaling and temperature dependence of vertebrate metabolism. <i>Biology Letters</i>, <i>2</i>(1), 125–127. <a target=\"_blank\" rel=\"noreferrer\" href=\"https://doi.org/10.1098/rsbl.2005.0378\">10.1098/rsbl.2005.0378</a>","url":"https://doi.org/10.1098/rsbl.2005.0378"}}}}}